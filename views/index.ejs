<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Message Board</title>
</head>
<body>
    <ul>
        <% messages.forEach((message) => { %>
            <li><%= message.text %></li>
            <li><%= message.user %></li>
            <li><%= message.added %></li>
        <%})%>
    </ul>
</body>
</html>